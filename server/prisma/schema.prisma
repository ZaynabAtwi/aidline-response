generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  VOLUNTEER
  COORDINATOR
  ADMIN
}

enum ResourceStatus {
  ACTIVE
  INACTIVE
  CLOSED
  FULL
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id               String              @id @default(cuid())
  fullName         String
  email            String              @unique
  passwordHash     String
  phone            String?
  role             UserRole            @default(USER)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  volunteerProfile Volunteer?
  medication       MedicationRequest[]
  sosRequests      SOSRequest[]
  chatMessages     ChatMessage[]       @relation("UserChatMessages")
}

model Clinic {
  id        String         @id @default(cuid())
  name      String
  district  String
  address   String
  phone     String?
  status    ResourceStatus @default(ACTIVE)
  latitude  Float?
  longitude Float?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Shelter {
  id        String         @id @default(cuid())
  name      String
  district  String
  address   String
  capacity  Int
  occupancy Int            @default(0)
  phone     String?
  status    ResourceStatus @default(ACTIVE)
  latitude  Float?
  longitude Float?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Volunteer {
  id           String         @id @default(cuid())
  userId       String?        @unique
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName     String
  phone        String?
  district     String
  skills       Json
  availability Boolean        @default(true)
  status       ResourceStatus @default(ACTIVE)
  latitude     Float?
  longitude    Float?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model MedicationRequest {
  id             String        @id @default(cuid())
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  medicationName String
  quantity       Int           @default(1)
  urgency        UrgencyLevel  @default(MEDIUM)
  district       String
  notes          String?
  status         RequestStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model GasStation {
  id        String         @id @default(cuid())
  name      String
  district  String
  address   String
  phone     String?
  fuelTypes Json
  status    ResourceStatus @default(ACTIVE)
  latitude  Float?
  longitude Float?
  updatedAt DateTime       @updatedAt
  createdAt DateTime       @default(now())
}

model SOSRequest {
  id            String        @id @default(cuid())
  userId        String?
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName      String
  phone         String?
  district      String
  emergencyType String
  notes         String?
  latitude      Float?
  longitude     Float?
  status        RequestStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ChatMessage {
  id         String   @id @default(cuid())
  senderId   String?
  sender     User?    @relation("UserChatMessages", fields: [senderId], references: [id], onDelete: SetNull)
  senderName String
  message    String
  channel    String   @default("general")
  district   String?
  createdAt  DateTime @default(now())
}
