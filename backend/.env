# AidLine Backend — Local Development
PORT=3001
NODE_ENV=development

# MySQL Database — update with your local MySQL credentials
DB_HOST=localhost
DB_PORT=3306
DB_USER=aidline
DB_PASSWORD=aidline_password
DB_NAME=aidline
DB_CONNECTION_LIMIT=10

# JWT — change in production
JWT_SECRET=aidline_dev_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
